# Put your Neon Postgres connection string here.
# Example:
# DATABASE_URL=postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/project_stock?sslmode=require
DATABASE_URL=postgres://postgres:password@db-host:5432/project_stock

# Optional token for the retention cleanup endpoint.
RETENTION_CRON_TOKEN=replace-with-a-random-secret
